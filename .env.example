# HamLoop environment — copy to .env.local and fill in real keys.
# .env.local is gitignored. NEVER commit real keys. NEVER prefix server
# keys with NEXT_PUBLIC_ (that would expose them to the browser).

# Which AI provider /api/ai-plan uses: mock | openai | anthropic
# Use "mock" for free local development (no key needed).
AI_PROVIDER=mock

# OpenAI (only needed when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (only needed when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
